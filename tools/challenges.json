  {
    "id": "py18",
    "title": "The Champion's Form",
    "mode": "function",
    "funcName": "Hero",
    "tests": [
      {
        "pysetup": "h = Hero('Bryn', 30)\nh.take_damage(10)",
        "expr": "h.hp",
        "expect": 20,
        "label": "take_damage(10): 30 -> 20"
      },
      {
        "pysetup": "h = Hero('Bryn', 30)\nh.take_damage(50)",
        "expr": "h.hp",
        "expect": 0,
        "label": "overkill floors at 0"
      },
      {
        "pysetup": "h = Hero('Bryn', 30)\nh.take_damage(50)",
        "expr": "h.is_alive()",
        "expect": false,
        "label": "fallen hero is_alive() False"
      },
      {
        "pysetup": "h = Hero('Sora', 5)\nh.heal(7)",
        "expr": "h.hp",
        "expect": 12,
        "label": "heal(7): 5 -> 12"
      },
      {
        "pysetup": "h = Hero('Sora', 5)",
        "expr": "h.is_alive()",
        "expect": true,
        "label": "standing hero is_alive() True"
      }
    ],
    "solution": "class Hero:\n    def __init__(self, name, hp):\n        self.name = name\n        self.hp = hp\n\n    def take_damage(self, n):\n        self.hp = max(0, self.hp - n)\n\n    def heal(self, n):\n        self.hp += n\n\n    def is_alive(self):\n        return self.hp > 0"
  },
