    "funcName": "clean_verse",
    "tests": [
      {
        "args": [
          "abcabcbb"
        ],
        "expect": 3,
        "label": "abcabcbb -> 3"
      },
      {
        "args": [
          "bbbbb"
        ],
        "expect": 1,
        "label": "bbbbb -> 1"
      },
      {
        "args": [
          "pwwkew"
        ],
        "expect": 3,
        "label": "pwwkew -> 3"
      },
      {
        "args": [
          ""
        ],
        "expect": 0,
        "label": "the empty verse"
      },
      {
        "args": [
          "firstking"
        ],
        "expect": 7,
        "label": "firstking -> 7 (rstking)"
      },
      {
        "args": [
          "au"
        ],
        "expect": 2,
        "label": "au -> 2"
      }
    ],
    "solution": "def clean_verse(s):\n    best = 0\n    for i in range(len(s)):\n        seen = set()\n        for ch in s[i:]:\n            if ch in seen:\n                break\n            seen.add(ch)\n        best = max(best, len(seen))\n    return best"
  }
